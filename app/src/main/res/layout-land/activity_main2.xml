<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity2">

    <ImageView
        android:id="@+id/img"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/img_2" />

    <Space
        android:id="@+id/space"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/ll_x"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@id/btn_leaders"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed">

        <FrameLayout
            android:id="@+id/btn3"
            android:layout_width="100dp"
            android:layout_height="57dp"
            android:background="@drawable/clipper_bcg"
            android:clipToOutline="true">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/btn_x_bcg" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="57dp"
                android:layout_gravity="center_horizontal"
                android:fontFamily="@font/ebon"
                android:gravity="center"
                android:text="3 x 3"
                android:textColor="#90adba"
                android:textSize="21sp"
                android:textStyle="bold" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/btn4"
            android:layout_width="100dp"
            android:layout_height="57dp"
            android:layout_marginHorizontal="5dp"
            android:background="@drawable/clipper_bcg"
            android:clipToOutline="true">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/btn_x_bcg" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="57dp"
                android:layout_gravity="center_horizontal"
                android:fontFamily="@font/ebon"
                android:gravity="center"
                android:text="4 x 4"
                android:textColor="#90adba"
                android:textSize="21sp"
                android:textStyle="bold" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/btn5"
            android:layout_width="100dp"
            android:layout_height="57dp"
            android:background="@drawable/clipper_bcg"
            android:clipToOutline="true">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/btn_x_bcg" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="57dp"
                android:layout_gravity="center_horizontal"
                android:fontFamily="@font/ebon"
                android:gravity="center"
                android:text="5 x 5"
                android:textColor="#90adba"
                android:textSize="21sp"
                android:textStyle="bold" />
        </FrameLayout>
    </LinearLayout>


    <FrameLayout
        android:id="@+id/btn_resume"
        android:layout_width="0dp"
        android:layout_height="57dp"
        android:layout_marginTop="5dp"
        android:background="@drawable/clipper_bcg"
        android:clipToOutline="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="@id/btn_leaders"
        app:layout_constraintRight_toRightOf="@id/btn_leaders"
        app:layout_constraintTop_toBottomOf="@+id/btn_leaders">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitXY"
            android:src="@drawable/btn_x_bcg" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="57dp"
            android:layout_gravity="center"
            android:layout_marginVertical="5dp"
            android:fontFamily="@font/cathra"
            android:gravity="center"
            android:letterSpacing="0.01"
            android:text="Resume game"
            android:textAllCaps="false"
            android:textColor="#90adba"
            android:textSize="23sp"
            android:textStyle="bold" />
    </FrameLayout>

    <FrameLayout
        android:id="@+id/btn_leaders"
        android:layout_width="0dp"
        android:layout_height="57dp"
        android:layout_marginTop="5dp"
        android:background="@drawable/clipper_bcg"
        android:clipToOutline="true"
        app:layout_constraintBottom_toTopOf="@id/btn_resume"
        app:layout_constraintLeft_toLeftOf="@id/ll_x"
        app:layout_constraintRight_toRightOf="@id/ll_x"
        app:layout_constraintTop_toBottomOf="@id/ll_x">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitXY"
            android:src="@drawable/btn_x_bcg" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="57dp"
            android:layout_gravity="center"
            android:layout_marginVertical="5dp"
            android:fontFamily="@font/cathra"
            android:gravity="center"
            android:letterSpacing="0.01"
            android:text="Leaderboard"
            android:textAllCaps="false"
            android:textColor="#90adba"
            android:textSize="23sp"
            android:textStyle="bold" />
    </FrameLayout>

    <ImageView
        android:id="@+id/info_btn"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_margin="13dp"
        android:background="@drawable/round_bcg"
        android:padding="9dp"
        android:src="@drawable/info"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/space" />
</androidx.constraintlayout.widget.ConstraintLayout>