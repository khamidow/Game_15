<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="19dp">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guide"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.5" />

    <ImageView
        android:id="@+id/title_img"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:scaleType="fitXY"
        android:src="@drawable/title_bcg"
        app:layout_constraintBottom_toTopOf="@id/dialog_img"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/title_victory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="19dp"
        android:fontFamily="@font/averia_libre_bold"
        android:gravity="center"
        android:text="Victory"
        android:textColor="#b8bfc2"
        android:textSize="33sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/title_img"
        app:layout_constraintLeft_toLeftOf="@id/title_img"
        app:layout_constraintRight_toRightOf="@id/title_img"
        app:layout_constraintTop_toTopOf="@id/title_img" />

    <ImageView
        android:id="@+id/dialog_img"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scaleType="fitXY"
        android:src="@drawable/win_dialog_bcg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/title_img" />

    <ImageView
        android:id="@+id/flag_drop1"
        android:layout_width="90dp"
        android:layout_height="180dp"
        android:layout_marginTop="-15dp"
        android:layout_marginRight="75dp"
        android:scaleType="fitXY"
        android:src="@drawable/flag_drop"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@id/flag_drop2"
        app:layout_constraintTop_toBottomOf="@+id/title_img" />

    <ImageView
        android:id="@+id/flag_drop2"
        android:layout_width="90dp"
        android:layout_height="180dp"
        android:layout_marginTop="-15dp"
        android:scaleType="fitXY"
        android:src="@drawable/flag_drop"
        app:layout_constraintLeft_toRightOf="@id/flag_drop1"
        app:layout_constraintRight_toRightOf="@id/guide"
        app:layout_constraintTop_toBottomOf="@+id/title_img" />

    <TextView
        android:id="@+id/number_1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/ebon"
        android:text="3"
        android:textColor="#b8bfc2"
        android:textSize="51dp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/flag_drop1"
        app:layout_constraintLeft_toLeftOf="@id/flag_drop1"
        app:layout_constraintRight_toRightOf="@id/flag_drop1"
        app:layout_constraintTop_toTopOf="@id/flag_drop1" />

    <TextView
        android:id="@+id/number_2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/ebon"
        android:text="3"
        android:textColor="#b8bfc2"
        android:textSize="51dp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/flag_drop2"
        app:layout_constraintLeft_toLeftOf="@id/flag_drop2"
        app:layout_constraintRight_toRightOf="@id/flag_drop2"
        app:layout_constraintTop_toTopOf="@id/flag_drop2" />

    <ImageView
        android:id="@+id/img_swords"
        android:layout_width="145dp"
        android:layout_height="145dp"
        android:layout_marginTop="29dp"
        android:src="@drawable/two_swords"
        app:layout_constraintLeft_toLeftOf="@id/dialog_img"
        app:layout_constraintRight_toRightOf="@id/guide"
        app:layout_constraintTop_toTopOf="@id/dialog_img" />

    <FrameLayout
        android:id="@+id/frame_move"
        android:layout_width="111dp"
        android:layout_height="50dp"
        android:layout_margin="13dp"
        android:background="@drawable/clipper_bcg"
        android:clipToOutline="true"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@id/frame_time"
        app:layout_constraintTop_toBottomOf="@+id/img_swords">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitXY"
            android:src="@drawable/img_3" />

        <ImageView
            android:layout_width="41dp"
            android:layout_height="41dp"
            android:layout_gravity="center_vertical"
            android:layout_marginLeft="3dp"
            android:padding="5dp"
            android:src="@drawable/move_icon" />

        <TextView
            android:id="@+id/count"
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            android:layout_gravity="end"
            android:layout_marginRight="1dp"
            android:fontFamily="@font/adorgan"
            android:gravity="center"
            android:letterSpacing="0.09"
            android:paddingHorizontal="15dp"
            android:text="0"
            android:textColor="#90adba"
            android:textSize="18sp"
            android:textStyle="bold" />
    </FrameLayout>

    <FrameLayout
        android:id="@+id/frame_time"
        android:layout_width="111dp"
        android:layout_height="50dp"
        android:layout_marginTop="11dp"
        android:background="@drawable/clipper_bcg"
        android:clipToOutline="true"
        app:layout_constraintLeft_toRightOf="@id/frame_move"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/img_swords">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitXY"
            android:src="@drawable/img_3" />

        <ImageView
            android:layout_width="41dp"
            android:layout_height="41dp"
            android:layout_gravity="center_vertical"
            android:layout_marginLeft="3dp"
            android:padding="5dp"
            android:src="@drawable/compass_time" />

        <TextView
            android:id="@+id/time"
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            android:layout_gravity="end"
            android:layout_marginRight="1dp"
            android:fontFamily="@font/adorgan"
            android:gravity="center"
            android:letterSpacing="0.09"
            android:paddingHorizontal="15dp"
            android:text="00:00"
            android:textColor="#90adba"
            android:textSize="18sp"
            android:textStyle="bold" />
    </FrameLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv"
        android:layout_width="0dp"
        android:layout_height="149dp"
        android:layout_marginTop="19dp"
        android:layout_marginRight="39dp"
        android:fadingEdgeLength="29dp"
        android:requiresFadingEdge="vertical"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintLeft_toLeftOf="@id/guide"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="@+id/dialog_img"
        tools:listitem="@layout/item_records" />

    <FrameLayout
        android:id="@+id/ok_btn"
        android:layout_width="131dp"
        android:layout_height="47dp"
        android:layout_marginTop="19dp"
        android:background="@drawable/clipper_bcg"
        android:clipToOutline="true"
        app:layout_constraintBottom_toBottomOf="@id/frame_time"
        app:layout_constraintLeft_toRightOf="@id/frame_move"
        app:layout_constraintRight_toLeftOf="@id/frame_time"
        app:layout_constraintTop_toTopOf="@id/frame_move">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitXY"
            android:src="@drawable/ok_btn_bcg" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:fontFamily="@font/averia_libre_bold"
            android:text="OK"
            android:textColor="#b8bfc2"
            android:textSize="19sp" />
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>