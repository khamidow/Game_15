<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="81dp"
    android:background="@drawable/clipper_item"
    android:clipToOutline="true">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:src="@drawable/item_bcg_img" />

    <ImageView
        android:id="@+id/img_cup"
        android:layout_width="41dp"
        android:layout_height="41dp"
        android:layout_marginLeft="11dp"
        android:padding="1dp"
        android:src="@drawable/first_cup"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/type_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/ebon"
        android:text="4x4"
        android:textColor="#90adba"
        android:textSize="23sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toRightOf="@id/img_cup"
        app:layout_constraintRight_toLeftOf="@id/frame_move"
        app:layout_constraintTop_toTopOf="parent" />

    <FrameLayout
        android:id="@+id/frame_time"
        android:layout_width="95dp"
        android:layout_height="50dp"
        android:layout_marginRight="5dp"
        android:background="@drawable/clipper_bcg"
        android:clipToOutline="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitXY"
            android:src="@drawable/img_3" />

        <ImageView
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_gravity="center_vertical"
            android:layout_marginLeft="3dp"
            android:padding="5dp"
            android:src="@drawable/compass_time" />

        <TextView
            android:id="@+id/time"
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            android:layout_gravity="end"
            android:layout_marginRight="1dp"
            android:fontFamily="@font/adorgan"
            android:gravity="center"
            android:letterSpacing="0.09"
            android:paddingHorizontal="15dp"
            android:text="00:00"
            android:textColor="#90adba"
            android:textSize="15sp"
            android:textStyle="bold" />
    </FrameLayout>

    <FrameLayout
        android:id="@+id/frame_move"
        android:layout_width="81dp"
        android:layout_height="50dp"
        android:layout_marginRight="5dp"
        android:background="@drawable/clipper_bcg"
        android:clipToOutline="true"
        app:layout_constraintBottom_toBottomOf="@id/frame_time"
        app:layout_constraintRight_toLeftOf="@id/frame_time"
        app:layout_constraintTop_toTopOf="@id/frame_time">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitXY"
            android:src="@drawable/img_3" />

        <ImageView
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_gravity="center_vertical"
            android:layout_marginLeft="3dp"
            android:padding="5dp"
            android:src="@drawable/move_icon" />

        <TextView
            android:id="@+id/count"
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            android:layout_gravity="end"
            android:layout_marginRight="1dp"
            android:fontFamily="@font/adorgan"
            android:gravity="center"
            android:letterSpacing="0.09"
            android:paddingHorizontal="15dp"
            android:text="000"
            android:textColor="#90adba"
            android:textSize="15sp"
            android:textStyle="bold" />
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>