<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.GitaGame15" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->

        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorAccent">@color/colorAccent</item>

        <!-- Defining that new color in ColorPrimaryDark -->
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
    </style>

    <style name="Theme.GitaGame15" parent="Base.Theme.GitaGame15" />

    <style name="Numbers">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:textSize">27sp</item>
        <item name="android:background">@drawable/item_bcg</item>
        <item name="android:layout_margin">3dp</item>
        <item name="android:clipToOutline" tools:targetApi="31">true</item>
        <item name="android:gravity">center</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">#101910</item>
    </style>

    <style name="your_style_name">
        <item name="android:scrollbarAlwaysDrawVerticalTrack">true</item>
        <item name="android:scrollbarStyle">insideOverlay</item>
        <item name="android:scrollbars">vertical</item>
        <item name="android:fadeScrollbars">false</item>
        <item name="android:scrollbarThumbVertical">@drawable/scroll_thing</item>
    </style>

    <style name="Numbers1">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:clipToOutline" tools:targetApi="31">true</item>
        <item name="android:textSize">27sp</item>
        <item name="android:background">@drawable/item_bcg</item>
        <item name="android:layout_margin">2.1dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">#101910</item>
    </style>
</resources>